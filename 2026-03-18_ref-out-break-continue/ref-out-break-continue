using System;

public class Einkaufsliste
{
    private string[] artikel = new string[10];
    private int zaehler = 0;

    public int Anzahl
    {
        get { return zaehler; }
    }

    public bool VersucheHinzufuegen(string artikelName, out string meldung)
    {
        if (zaehler < artikel.Length)
        {
            artikel[zaehler] = artikelName;
            zaehler++;

            meldung = "Artikel wurde hinzugefügt!";
            return true;
        }
        else
        {
            meldung = "Liste ist voll!";
            return false;
        }
    }

    public bool Enthaelt(string gesuchterArtikel)
    {
        bool gefunden = false;

        for (int i = 0; i < zaehler; i++)
        {
            if (artikel[i] == gesuchterArtikel)
            {
                gefunden = true;
                break; // Suche wird abgebrochen, wenn Artikel gefunden wurde
            }
        }

        return gefunden;
    }


    public void GibKurzeNamenAus(int minLaenge)
    {
        for (int i = 0; i < zaehler; i++)
        {
            if (artikel[i].Length >= minLaenge)
            {
                continue; // Überspringt Artikel, die länger oder gleich der Mindestlänge sind
            }

            Console.WriteLine(artikel[i]);
        }
    }


    public void VergleicheStrings()
    {
        string a = "Milch";
        string b = "Mil" + "ch";

        bool vergleich1 = (a == b);
        bool vergleich2 = a.Equals(b);

        Console.WriteLine("== Ergebnis: " + vergleich1);
        Console.WriteLine(".Equals() Ergebnis: " + vergleich2);

        if (vergleich1 == vergleich2)
        {
            Console.WriteLine("Beide Vergleiche liefern das gleiche Ergebnis.");
        }
        else
        {
            Console.WriteLine("Die Vergleiche sind unterschiedlich.");
        }
    }
}