@page "/anime/watching"
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject AnimeDbContext Db
@using Microsoft.EntityFrameworkCore

<h3>Still Watching Animes</h3>

<a href="/anime" class="back-btn">Back to Search</a>

@if (editingAnime != null)
{
    <div class="add-form">
        <h4>Edit @editingAnime.Title</h4>
        <label>Rating (0-10): 
            <input type="number" @bind="editingAnime.Rating" min="0" max="10" />
        </label>
        <label style="display: block; margin-top: 10px;">
            Details/Notes:
            <textarea @bind="editingAnime.Details" style="width: 100%; height: 80px; margin-top: 5px;"></textarea>
        </label>
        <div style="margin-top: 15px;">
            <button class="back-btn" @onclick="SaveChanges">Save</button>
            <button class="anime-item button" @onclick="() => editingAnime = null">Cancel</button>
        </div>
    </div>
}

@if (watchingAnimes.Any())
{
    <div class="list-grid">
        @foreach (var anime in watchingAnimes)
        {
            <div class="anime-item">
                <img src="@anime.ImageUrl" alt="@anime.Title" @onclick="() => GoToDetails(anime)" />
                <p @onclick="() => GoToDetails(anime)">@anime.Title</p>
                <p class="episodes" @onclick="() => GoToDetails(anime)">@anime.Episodes episodes</p>
                <p class="rating" @onclick="() => GoToDetails(anime)">Rating: @anime.Rating/10</p>
                <button class="back-btn" style="padding: 5px 10px; font-size: 12px; margin: 5px 15px;" @onclick="() => StartEdit(anime)">Edit</button>
                <button @onclick="() => DeleteAnime(anime)">Remove</button>
            </div>
        }
    </div>
}
else
{
    <p>No animes being watched yet.</p>
}

@code {
    private List<AnimeItem> watchingAnimes = new();
    private AnimeItem? editingAnime = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadFromDatabase();
    }

    private async Task LoadFromDatabase()
    {
        watchingAnimes = await Db.AnimeItems.Where(a => a.WatchStatus == "Watching").ToListAsync();
        Console.WriteLine($"Loaded {watchingAnimes.Count} watching animes from DB");
    }

    private void GoToDetails(AnimeItem anime)
    {
        Nav.NavigateTo($"/anime/details/{anime.MalId}");
    }

    private void StartEdit(AnimeItem anime)
    {
        editingAnime = new AnimeItem
        {
            MalId = anime.MalId,
            Title = anime.Title,
            ImageUrl = anime.ImageUrl,
            Synopsis = anime.Synopsis,
            Episodes = anime.Episodes,
            Status = anime.Status,
            WatchStatus = anime.WatchStatus,
            Details = anime.Details,
            Rating = anime.Rating,
            ShowDetails = anime.ShowDetails
        };
    }

    private async Task SaveChanges()
    {
        var anime = await Db.AnimeItems.FirstOrDefaultAsync(a => a.MalId == editingAnime!.MalId && a.WatchStatus == editingAnime.WatchStatus);
        if (anime != null)
        {
            anime.Rating = editingAnime.Rating;
            anime.Details = editingAnime.Details;
            await Db.SaveChangesAsync();
            editingAnime = null;
            await LoadFromDatabase();
            StateHasChanged();
        }
    }

    private async Task DeleteAnime(AnimeItem anime)
    {
        var item = await Db.AnimeItems.FirstOrDefaultAsync(a => a.MalId == anime.MalId && a.WatchStatus == anime.WatchStatus);
        if (item != null)
        {
            Db.AnimeItems.Remove(item);
            await Db.SaveChangesAsync();
            await LoadFromDatabase();
            StateHasChanged();
        }
    }
}