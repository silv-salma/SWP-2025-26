    <a href="/genshin/builds" class="genshin-card">
        <div class="card-icon">BUILD</div>
        <h4>Build Guide</h4>
        <p>Best weapons and artifacts for each character</p>
    </a>

    <a href="/genshin/wiki" class="genshin-card">
        <div class="card-icon">WIKI</div>
        <h4>Genshin Wiki</h4>
        <p>Browse all game data and encyclopedia</p>
    </a>

    <a href="/genshin/farming" class="genshin-card">
        <div class="card-icon">FARM</div>
        <h4>Farming Planner</h4>
        <p>Plan your daily domain farming routes</p>
    </a>

    <a href="/genshin/compare" class="genshin-card">
        <div class="card-icon">COMP</div>
        <h4>Character Compare</h4>
        <p>Compare stats between characters</p>
