@page "/genshin"

<h3>Genshin Impact Hub</h3>

<div class="genshin-grid">
    <a href="/genshin/characters" class="genshin-card">
        <div class="card-icon">CHAR</div>
        <h4>Character Tracker</h4>
        <p>Track your characters, levels, and talents</p>
    </a>

    <a href="/genshin/teambuilder" class="genshin-card">
        <div class="card-icon">TEAM</div>
        <h4>Team Builder</h4>
        <p>Build optimal teams with element synergy</p>
